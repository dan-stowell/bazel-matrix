# Bazel Matrix build configuration.

# Bzlmod is the only dependency system used in this repo.
common --enable_bzlmod
common --noenable_workspace

# Make actions see a consistent environment for reproducibility.
build --incompatible_strict_action_env

# RBE targets pass this through to the inner Bazel invocation when present.
build --action_env=BUILDBUDDY_API_KEY

# Matrix targets run one inner Bazel invocation per action. Keep the outer Bazel
# scheduler serial so a sweep does not launch many projects at once; inner Bazel
# invocations ignore this rc file and keep their own parallelism.
build --jobs=1

# Publish anonymous, public BuildBuddy invocation links for outer Bazel runs.
build --bes_results_url=https://app.buildbuddy.io/invocation/
build --bes_backend=grpcs://remote.buildbuddy.io
build --build_metadata=USER=bazel-matrix
build --build_metadata=VISIBILITY=PUBLIC
build --credential_helper=remote.buildbuddy.io=%workspace%/tools/buildbuddy_credential_helper.py

# Quieter, more useful test output.
test --test_output=errors
# Let Bazel upload BEP-referenced test logs to BuildBuddy when
# BUILDBUDDY_API_KEY is present. Do not use the outer invocation as a general
# remote cache for local action results.
test --remote_cache=grpcs://remote.buildbuddy.io
test --remote_build_event_upload=minimal
test --noremote_upload_local_results

# Host-specific tuning (not committed), e.g. a shared inner repository cache:
#   test --test_env=BAZEL_RUNNER_REPO_CACHE=<abs path>
#   test --sandbox_writable_path=<same abs path>
# Without it, every inner test invocation refetches all external archives.
try-import %workspace%/user.bazelrc
